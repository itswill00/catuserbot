# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~# CatUserBot #~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~#
# This is a template configuration file for CatUserbot.
# Copy this file to '.env' and fill in the required data.
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~#

# --- CORE BOT SETTINGS (REQUIRED) ---

# Get APP_ID and API_HASH from https://my.telegram.org
APP_ID=
API_HASH=

# Your account's String Session. Generate this by running 'python stringsetup.py'
STRING_SESSION=

# --- ASSISTANT BOT SETTINGS (OPTIONAL BUT RECOMMENDED) ---

# Bot Token from @BotFather for the assistant bot functionality
TG_BOT_TOKEN=
# Assistant Bot Username (e.g., @MyAssistantBot)
TG_BOT_USERNAME=

# --- LOGGING & PERMIT ---

# Group ID for Bot Logs (Private Channel/Group). Enter the full ID (e.g., -100123456789)
PRIVATE_GROUP_BOT_API_ID=0

# Group ID for Private Message (PM) Logging.
PM_LOGGER_GROUP_ID=0

# Your Telegram User ID (Owner). Set to 0 for auto-detection.
OWNER_ID=0

# --- CUSTOMIZATION ---

# Character used to trigger bot commands (default: .)
COMMAND_HAND_LER=.
# Character used to trigger Sudo commands (default: .)
SUDO_COMMAND_HAND_LER=.

# Name displayed in the .alive command
ALIVE_NAME=CatUserbot

# Timezone (e.g., Asia/Jakarta or UTC)
TZ=UTC

# URL of the thumbnail image used in inline menus
THUMB_IMAGE=https://graph.org/file/ca95524e4734b0d5461b5.jpg

# --- UPSTREAM & UPDATES ---

# Source repository for code updates
UPSTREAM_REPO=https://github.com/itswill00/catuserbot
UPSTREAM_REPO_BRANCH=master

# Channel ID for external plugin logs
PLUGIN_CHANNEL=0

# --- EXTERNAL API KEYS ---

# Get your key at https://platform.openai.com
OPENAI_API_KEY=

# Get your key from @SpamWatchBot
SPAMWATCH_API=

# Get your token at https://genius.com/api-clients
GENIUS_API_TOKEN=

# --- HEROKU SETTINGS (ONLY FOR HEROKU DEPLOYMENT) ---
HEROKU_APP_NAME=
HEROKU_API_KEY=

# --- MISCELLANEOUS ---

# List of plugins to exclude from loading (space-separated)
NO_LOAD=

# Progress bar characters
FINISHED_PROGRESS_STR=█
UNFINISHED_PROGRESS_STR=░
